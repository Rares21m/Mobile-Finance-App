generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String           @id @default(uuid())
  email                 String           @unique
  passwordHash          String
  name                  String?
  profileGoal           String?          // savings | expense_control | investment | debt_freedom
  profileIncomeRange    String?          // under_1500 | 1500_3000 | 3000_6000 | over_6000
  profileCategories     String?          // JSON array, e.g. '["food","transport"]'
  avatar                String?          // base64 data URI, e.g. 'data:image/jpeg;base64,...'
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  bankConnections              BankConnection[]
  budgetLimits                 BudgetLimit[]
  eventBudgets                 EventBudget[]
  savingsGoals                 SavingsGoal[]
  manualTransactions           ManualTransaction[]
  transactionCategoryOverrides TransactionCategoryOverride[]
  idempotencyKeys              IdempotencyKey[]
  monthlyTransactionSummaries  MonthlyTransactionSummary[]
}

model BudgetLimit {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  String
  amount    Decimal
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, category])
  @@index([userId])
}

model EventBudget {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  totalLimit Decimal
  startDate  DateTime
  endDate    DateTime
  categories String   @default("[]")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

model SavingsGoal {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  targetAmount Decimal
  savedAmount  Decimal   @default(0)
  deadline     DateTime?
  icon         String    @default("star-outline")
  color        String    @default("#10B981")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
}

model BankConnection {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankName       String        // "BT", "ING", etc.
  consentId      String?
  clientId       String?
  clientSecret   String?
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  codeVerifier   String?
  status         String        @default("pending") // pending, active, expired, revoked
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  transactions   Transaction[]
}

model Transaction {
  id               String         @id @default(uuid())
  bankConnectionId String
  bankConnection   BankConnection @relation(fields: [bankConnectionId], references: [id], onDelete: Cascade)
  transactionId    String?
  canonicalId      String?
  amount           Decimal
  currency         String         @default("RON")
  sourceLabel      String         @default("synced")
  creditorName     String?
  debtorName       String?
  merchantNormalized String?
  inferredCategory String?
  bookingDate      DateTime?
  valueDate        DateTime?
  normalizedBookingDate DateTime?
  normalizedValueDate   DateTime?
  remittanceInfo   String?
  payloadHash      String?
  syncBatchId      String?
  isDuplicate      Boolean        @default(false)
  duplicateOfId    String?
  duplicateOf      Transaction?   @relation("TransactionDuplicates", fields: [duplicateOfId], references: [id], onDelete: SetNull)
  duplicates       Transaction[]  @relation("TransactionDuplicates")
  category         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([bankConnectionId])
  @@index([bookingDate(sort: Desc)])
  @@index([bankConnectionId, bookingDate(sort: Desc)])
  @@index([bankConnectionId, valueDate(sort: Desc)])
  @@index([canonicalId])
  @@index([merchantNormalized])
  @@index([isDuplicate, canonicalId])
  @@unique([bankConnectionId, canonicalId])
}



model ManualTransaction {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Decimal
  currency    String   @default("RON")
  description String
  category    String   @default("other")
  date        DateTime
  isExpense   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([userId, date(sort: Desc)])
  @@index([date])
}

model TransactionCategoryOverride {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactionId String
  category      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, transactionId])
  @@index([userId])
  @@index([userId, updatedAt(sort: Desc)])
}

model IdempotencyKey {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint       String
  key            String
  requestHash    String
  responseStatus Int?
  responseBody   Json?
  createdAt      DateTime @default(now())
  expiresAt      DateTime

  @@unique([userId, endpoint, key])
  @@index([expiresAt])
}

model MonthlyTransactionSummary {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  monthStart    DateTime
  currency      String   @default("RON")
  incomeTotal   Decimal  @default(0)
  expenseTotal  Decimal  @default(0)
  netTotal      Decimal  @default(0)
  transactionCount Int   @default(0)
  manualCount   Int      @default(0)
  syncedCount   Int      @default(0)
  inferredCount Int      @default(0)
  cachedCount   Int      @default(0)
  topCategory   String?
  topMerchant   String?
  sourceUpdatedAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, monthStart, currency])
  @@index([userId, monthStart(sort: Desc)])
}
